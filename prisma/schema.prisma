generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  fullName  String?
  phone     String?
  createdAt DateTime @default(now())

  records ItemRecord[]
}

model ItemRecord {
  id          String   @id
  assetName   String
  ownerName   String
  phone       String
  email       String
  description String
  category    String
  status      String
  createdAt   DateTime

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  finderMessages FinderMessage[]
}

model FinderMessage {
  id                  String    @id
  recordId            String
  finderName          String
  finderPhone         String
  finderEmail         String?
  location            String
  message             String
  status              String
  emailDeliveryStatus String?
  emailDeliveredAt    DateTime?
  createdAt           DateTime

  record ItemRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
}